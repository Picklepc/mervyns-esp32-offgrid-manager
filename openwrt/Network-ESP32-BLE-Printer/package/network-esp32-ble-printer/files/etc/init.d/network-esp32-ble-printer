#!/bin/sh /etc/rc.common

START=95
USE_PROCD=1

SERVICE_NAME="network-esp32-ble-printer"
PROG="/usr/bin/python3"
SCRIPT="/usr/libexec/network-esp32-ble-printer/bridge.py"
SETUP_SCRIPT="/usr/libexec/network-esp32-ble-printer/setup-cups-docker.sh"

start_service() {
	[ -x "$SETUP_SCRIPT" ] && "$SETUP_SCRIPT" apply || true
	procd_open_instance
	procd_set_param command "$PROG" "$SCRIPT" daemon
	procd_set_param respawn 3600 5 5
	procd_set_param stdout 1
	procd_set_param stderr 1
	procd_close_instance
}

stop_service() {
	[ -x "$SETUP_SCRIPT" ] && "$SETUP_SCRIPT" stop || true
	:
}

reload_service() {
	stop
	start
}
