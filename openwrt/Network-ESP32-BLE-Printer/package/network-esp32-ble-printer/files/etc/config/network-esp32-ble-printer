config bridge 'main'
	option enabled '1'
	option esp_url 'http://192.168.1.4'
	option printer_name 'Mervyns Label Printer'
	option host_profile 'nespi'
	option listen_host '0.0.0.0'
	option bridge_port '8631'
	option public_ipp_port '631'
	option web_path '/'
	option ipp_path '/ipp/print'
	option poll_interval '30'
	option esp_timeout_sec '5'
	option backend_timeout_sec '8'
	option printer_status_ttl_sec '10'
	option printer_ready_stale_ms '20000'
	option data_root '/mnt/sda1/network-esp32-ble-printer'
	option spool_dir ''
	option cache_dir ''
	option advertise_service '1'
	option cups_enabled '1'
	option cups_container_name 'mervyns-cups'
	option cups_image 'olbat/cupsd:latest'
	option cups_data_root '/mnt/sda1/network-esp32-ble-printer/cups'
	option keep_failed_jobs '1'
	option system_scale_percent '100'
	option system_vertical_bias_percent '-10'
	option purge_completed_jobs '1'
	option purge_completed_jobs_delay_sec '8'
	option trim_white_border '0'
